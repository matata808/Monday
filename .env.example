APP_URL=http://127.0.0.1:5173
API_HOST=127.0.0.1
API_PORT=8787
APP_SECRET=replace-with-a-long-random-local-secret

# PostgreSQL. Leave DATABASE_URL empty to use SQLite for local zero-setup dev.
POSTGRES_DB=dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=replace-with-a-local-dev-password
DATABASE_URL=

# Zero-setup local DBMS used by default for personal/local development.
SQLITE_DATABASE_PATH=./data/dashboard.sqlite

# Google OAuth client for Gmail readonly sync.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/api/auth/google/callback

# ZFN IMAP settings. Fill this after confirming the actual ZFN IMAP host.
ZFN_IMAP_HOST=
ZFN_IMAP_PORT=993

# Weather integration. Open-Meteo does not require an API key.
# For OpenWeather or another provider, put the key in WEATHER_API_KEY.
WEATHER_API_PROVIDER=open-meteo
WEATHER_API_KEY=
WEATHER_LOCATION=Berlin,DE
